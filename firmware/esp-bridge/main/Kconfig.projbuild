menu "ShadowChat Bridge"

config BRIDGE_SUPABASE_URL
    string "Supabase project URL"
    default ""
    help
        Base project URL, for example https://example.supabase.co

config BRIDGE_SUPABASE_ANON_KEY
    string "Supabase anon key"
    default ""
    help
        Anonymous API key used to invoke public bridge Edge Functions.

config BRIDGE_HARDWARE_MODEL
    string "Bridge hardware model"
    default "esp32-s3"

config BRIDGE_FIRMWARE_VERSION
    string "Bridge firmware version"
        default "0.2.6-bootstrap-autodetect"

config BRIDGE_UPDATE_CHANNEL
    string "Bridge update channel"
    default "stable"
    help
        Update manifest channel used for startup and manual firmware checks.
        Expected values are stable, beta, or dev.

config BRIDGE_USB_BOOTSTRAP_MSC
    bool "Expose first-plug bootstrap USB mass-storage drive"
    default y
    help
        Initializes a small FAT partition as a USB MSC bootstrap drive containing
        START.CMD, SETUP.CMD, README.TXT, and a PowerShell bundle receiver.

        This requires an ESP32-S3 board whose exposed USB connector is routed to
        the USB-OTG peripheral. Boards exposing only the fixed USB Serial/JTAG
        path may keep the serial bootstrap commands but will not show the drive.

config BRIDGE_DEVICE_SERIAL
    string "Bridge device serial override"
    default ""
    help
        Optional stable device serial override. Leave blank to derive a serial
        from the ESP MAC address at runtime.

endmenu
