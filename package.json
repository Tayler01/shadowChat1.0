{
  "name": "realtime-chat-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "qa:smoke": "node scripts/playwright-smoke.mjs",
    "qa:smoke:headed": "node scripts/playwright-smoke.mjs --headed",
    "qa:smoke:auth": "node scripts/playwright-smoke.mjs --scenario=auth",
    "qa:smoke:dm": "node scripts/playwright-smoke.mjs --scenario=dm",
    "qa:smoke:resume": "node scripts/playwright-smoke.mjs --scenario=resume-send",
    "qa:smoke:prod": "node scripts/playwright-smoke.mjs --base-url=https://shadowchat-1-0.netlify.app --scenario=auth,resume-send --account-mode=env --run-name=prod-postdeploy --headed --slow-mo=300",
    "qa:smoke:prod:headless": "node scripts/playwright-smoke.mjs --base-url=https://shadowchat-1-0.netlify.app --scenario=auth,resume-send --account-mode=env --run-name=prod-postdeploy-headless",
    "qa:smoke:prod:headed": "node scripts/playwright-smoke.mjs --base-url=https://shadowchat-1-0.netlify.app --scenario=auth,resume-send --account-mode=env --run-name=prod-postdeploy-headed --headed --slow-mo=300",
    "qa:smoke:mobile": "node scripts/playwright-smoke.mjs --scenario=mobile-dm-back",
    "qa:smoke:full": "node scripts/playwright-smoke.mjs --scenario=full",
    "bridge:tui": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/bridge-tui/bridge-tui.ps1",
    "bridge:tui:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/bridge-tui/bridge-tui.ps1 -Smoke",
    "bridge:bundle": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/bridge-tui/bridge-bundle-receive.ps1",
    "bridge:bundle:pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-bridge-bundle.ps1",
    "bridge:tui:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-bridge-tui-layout.ps1",
    "qa:smoke:full:headed": "node scripts/playwright-smoke.mjs --scenario=full --headed"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "clsx": "^2.0.0",
    "emoji-picker-react": "^4.7.15",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "sentiment": "^5.0.2",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.10",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.4",
    "playwright": "^1.59.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
