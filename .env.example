# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard
# Navigate to Settings > API to find your Project URL and anon/public key
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Configuration
# Browser AI calls go through the Supabase `openai-chat` Edge Function.
# Set these in Supabase Edge Function secrets, not in the browser env.
# Recommended cheap OpenRouter test model as of 2026-04-26:
# OPENROUTER_API_KEY=your_openrouter_api_key
# AI_PROVIDER=openrouter
# OPENROUTER_MODEL=mistralai/mistral-nemo
# AI_ALLOWED_MODELS=mistralai/mistral-nemo
# OPENROUTER_SITE_URL=https://shadowchat-1-0.netlify.app
# OPENROUTER_APP_NAME=ShadowChat
#
# Legacy fallback, only if using OpenAI instead of OpenRouter:
# OPENAI_KEY=your_openai_api_key

# Optional: Presence update interval in milliseconds (default: 30000)
VITE_PRESENCE_INTERVAL_MS=30000

# Optional: Number of messages to fetch per request (default: 50)
VITE_MESSAGE_FETCH_LIMIT=50

# Optional: Enable verbose logging for Supabase requests (true/false, defaults to true in dev)
VITE_DEBUG_LOGS=true

# Web Push Configuration
# Public VAPID key for browser push subscriptions.
# Keep the matching private key in Supabase secrets, not in this file.
VITE_WEB_PUSH_PUBLIC_KEY=your_web_push_public_key

# Supabase Edge Function secrets for Web Push
# WEB_PUSH_PUBLIC_KEY=your_web_push_public_key
# WEB_PUSH_PRIVATE_KEY=your_web_push_private_key
# WEB_PUSH_SUBJECT=https://your-app.example.com

# Supabase Edge Function secrets for provider-specific link previews.
# Keep these server-side in Supabase secrets only.
# META_OEMBED_ACCESS_TOKEN=your_meta_oembed_access_token
# META_APP_ID=your_meta_app_id
# META_APP_SECRET=your_meta_app_secret

# Supabase Edge Function secret for the General Chat GIF picker.
# Keep this server-side only. Do not add a VITE_ Klipy key.
# KLIPY_API_KEY=your_klipy_api_key

# Render News scraper environment.
# Keep these server-side in Render only; do not expose service-role keys through Vite.
# SUPABASE_URL=https://your_project_ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# NEWS_SCRAPE_INTERVAL_MS=90000
# NEWS_SCRAPE_HEADLESS=true
# PINCHTAB_CDP_URL=
# PINCHTAB_WS_ENDPOINT=
# X_USERNAME=
# X_EMAIL=
# X_PASSWORD=
# TRUTH_USERNAME=
# TRUTH_EMAIL=
# TRUTH_PASSWORD=
# NEWS_X_SHARED_CONTEXT=false

# Storage Configuration
# Ensure these buckets exist in your Supabase project:
# - chat-uploads (for file uploads)
# - message-media (for voice messages)
# - avatars (for user avatars)
# - banners (for user banners)

# CORS Configuration Required
# In your Supabase dashboard, go to Settings > API > CORS
# Add your development URL (e.g., http://localhost:5173) to allowed origins

# Optional: stable Playwright smoke accounts.
# Production smoke must use two existing, email-confirmed accounts because
# production signup may require email confirmation and return no active session.
# Store real local credentials in `.env.testing.local`; that file is gitignored.
# The smoke runner loads `.env`, then `.env.testing.local`, then process env.
# Local smoke can omit these and create disposable accounts automatically.
# PLAYWRIGHT_ACCOUNT_1_EMAIL=smoke-user-1@example.com
# PLAYWRIGHT_ACCOUNT_1_PASSWORD=change_me
# PLAYWRIGHT_ACCOUNT_1_USERNAME=smokeuser1
# PLAYWRIGHT_ACCOUNT_1_DISPLAY_NAME=Smoke User 1
# PLAYWRIGHT_ACCOUNT_2_EMAIL=smoke-user-2@example.com
# PLAYWRIGHT_ACCOUNT_2_PASSWORD=change_me
# PLAYWRIGHT_ACCOUNT_2_USERNAME=smokeuser2
# PLAYWRIGHT_ACCOUNT_2_DISPLAY_NAME=Smoke User 2
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4174
